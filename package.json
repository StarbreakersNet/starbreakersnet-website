    "@tailwindcss/postcss": "^4.1.16",
    "@tailwindcss/vite": "^4.1.16",
    "@tsparticles/slim": "^3.5.0",
    "@tsparticles/vue3": "^3.0.1",
    "lodash": "^4.17.21",
    "luxon": "^3.7.2",
    "pinia": "^3.0.3",
    "tailwindcss": "^4.1.16",
