    "eslint-plugin-vue": "~10.5.0",
    "jiti": "^2.6.1",
    "naive-ui": "^2.39.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.23.0",
    "prettier": "^3.6.2",
